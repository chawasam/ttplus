# ===== TTplus Backend — Environment Variables =====
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# *** ห้าม commit ไฟล์ .env ขึ้น GitHub เด็ดขาด ***

NODE_ENV=development
# production ให้เปลี่ยนเป็น: NODE_ENV=production

PORT=4000
FRONTEND_URL=http://localhost:3000
# production: FRONTEND_URL=https://your-domain.com

# Firebase Admin SDK (เอาจาก Service Account JSON)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Security Salt สำหรับ hash IP (สร้างด้วย: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
IP_HASH_SALT=replace_with_random_64char_hex_string
